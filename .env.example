# ─────────────────────────────────────────────────────────────
# recovery-wear-guide.com SEO週次ルーチン 環境変数
# 実際の値は .env にコピーして設定する（.env はコミット禁止）
# ─────────────────────────────────────────────────────────────

# ── Google (Search Console + GA4) ──
# サービスアカウントJSONキーの「中身」をbase64エンコードした1行文字列
#   例(mac/linux): base64 -w0 service-account.json
#   例(win/PowerShell): [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json"))
GOOGLE_SERVICE_ACCOUNT_JSON=
# GA4 プロパティID（管理→プロパティ設定 の数字のみ。例: 123456789）
GA4_PROPERTY_ID=
# GSC 対象サイト。URLプレフィックスプロパティなら末尾スラッシュ付きURL、
# ドメインプロパティなら "sc-domain:recovery-wear-guide.com" 形式
GSC_SITE_URL=https://recovery-wear-guide.com/

# ── WordPress (REST API / アプリケーションパスワード) ──
WP_BASE_URL=https://recovery-wear-guide.com
# アプリケーションパスワードを発行したユーザー名（ログインID）
WP_USERNAME=
# 発行されたアプリケーションパスワード（スペースは含めたままでOK）
WP_APP_PASSWORD=

# ── Claude API ──
ANTHROPIC_API_KEY=
# ドラフト生成に使うモデルID（下記「未確認」参照。既定は claude-sonnet-5）
ANTHROPIC_MODEL=claude-sonnet-5

# ── 状態管理（外部DBなし） ──
# 提案履歴・重複判定・却下判定は WordPress 自身のデータ（publish/draft/trash の記事）で行う。
# 追加の接続情報は不要。判定に使う認証情報は上記 WordPress セクション（WP_*）を利用する。

# ── 動作設定 ──
# 1回の実行で生成するドラフト上限（リライト+新規の合計）
MAX_DRAFTS_PER_RUN=3
# 分析対象期間（日数）
LOOKBACK_DAYS=28
# GSCデータ遅延を考慮し、分析期間の終端を「実行日のN日前」にする
DATA_DELAY_DAYS=3
# true ならWP投稿せずログ出力のみ（テストモード）
DRY_RUN=true
